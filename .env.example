# Copy this file to ".env" and fill in your values.
#
# Microsoft Entra application (client) ID of the SPA app registration.
VITE_AAD_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Tenant ID (GUID) of the Fabric tenant, or "organizations" / "common".
VITE_AAD_TENANT_ID=organizations

# Set to "true" to enable LIVE Admin Mode write operations (scale / pause /
# resume capacities via Azure Resource Manager, and workspace moves via the
# Fabric REST API). Leave unset/false to run write actions against a local
# simulation. Live writes additionally require:
#   * Entra app permissions: Azure Service Management (user_impersonation) and
#     Fabric Capacity.ReadWrite.All + Workspace.ReadWrite.All (admin-consented).
#   * The signed-in user to hold the required RBAC on the target capacities
#     (read/write + suspend/resume actions) and workspace admin for moves.
VITE_ADMIN_LIVE_WRITES=false
